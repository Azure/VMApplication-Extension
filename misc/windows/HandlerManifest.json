[{
  "version": 1.0,
  "handlerManifest": {
    "installCommand": "install.cmd",
    "uninstallCommand": "bin\\vm-application-manager.exe uninstall",
    "updateCommand": "update.cmd",
    "enableCommand": "bin\\extension-launcher.exe -extensionname 'Microsoft.CPlat.Core.VMApplicationWindows' -extensionversion '1.0.7' -exename .\\vm-application-manager.exe -operation enable",
    "disableCommand": "bin\\vm-application-manager.exe disable",
    "rebootAfterInstall": false,
    "reportHeartbeat": false,
    "updateMode": "UpdateWithInstall"
  }
}]
